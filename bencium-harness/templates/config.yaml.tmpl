# bencium-harness config

deploy:
  target: {{deploy_target}}      # fly.io | vercel | netlify | npm | other
  cmd: "{{deploy_cmd}}"          # full command run by /bencium-deploy
  health: "{{deploy_health}}"    # command that exits 0 if app is healthy
  url: "{{deploy_url}}"          # canonical base URL of the deployed app — used by
                                 # /bencium-deploy Step 5.5 SMOKE to re-walk
                                 # ACCEPTANCE.md items tagged [deployed] against
                                 # the live environment. Local pass != shipped.

rollback:
  cmd: "{{rollback_cmd}}"        # full command run by /bencium-rollback

verify:
  # Optional hard-check commands run by /bencium-verify before walking ACCEPTANCE.md.
  # Each entry is { name, cmd }. The verify step fails if any cmd exits non-zero.
  cmd: []
  # Example:
  # cmd:
  #   - name: tests
  #     cmd: npm test -- --run
  #   - name: typecheck
  #     cmd: npm run typecheck
  #   - name: build
  #     cmd: npm run build
